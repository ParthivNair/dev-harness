# Copy to `.env` and fill in. `.env` is gitignored.
# The harness reads HARNESS_GITHUB_TOKEN from the environment (not from TOML).
# Fine-grained PAT scopes: Issues=RW, Pull requests=RW, Metadata=R, Contents=RW.
#
# Note: the engine reads this from the actual environment. Either export it in your
# shell, or use a tool (direnv, dotenv) to load this file — the harness does not
# parse .env itself in Milestone 1.
HARNESS_GITHUB_TOKEN=github_pat_replace_me
