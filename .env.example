# Copy to `.env` and fill in. `.env` is gitignored and MACHINE-LOCAL (each machine
# gets its own; never commit it). These are SECRETS — never put them in any .toml.
#
# If python-dotenv is installed (it is, by default), the harness auto-loads this
# file from the harness.toml directory. A real exported variable always overrides
# it. This matters because always-on runtimes (Windows Task Scheduler, launchd,
# services) do NOT inherit your interactive shell's exports.

# --- GitHub: the cross-machine coordination substrate ---
# Fine-grained PAT for the coordination + managed repos.
# Scopes: Issues=RW, Pull requests=RW, Contents=RW, Metadata=R.
HARNESS_GITHUB_TOKEN=github_pat_replace_me

# --- Discord: notifier + bridge bot (optional; only if notifier.selection="discord") ---
# Bot token from the Discord Developer Portal (Bot -> Reset Token). Used by BOTH the
# DiscordNotifier's REST posts and the always-on `harness discord-bot`. The channel
# and guild IDs are NOT secrets — they live in harness.toml under [discord].
# DISCORD_BOT_TOKEN=replace_me

# --- Claude Code CLI auth: SEPARATE from the harness ---
# The executor shells out to `claude`; the CLI authenticates ITSELF. With an
# interactive/subscription login you need NOTHING here. Only set this if your Claude
# Code CLI uses API-key auth; it must be in the environment the `claude` subprocess
# inherits. The harness never reads it.
# ANTHROPIC_API_KEY=sk-ant-replace_me_only_if_using_api_key_auth
