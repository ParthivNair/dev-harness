# Instance config TEMPLATE. Copy to `harness.toml` and edit per machine.
#
# This file describes ONE install. The same engine runs on every machine; what
# differs is this file (identity + which repos this machine knows about) and the
# local environment. Each install acts only on projects whose `owner_instance`
# matches `instance.instance_id`.
#
# The GitHub token is NEVER stored here. Export it instead:
#     PowerShell:  $env:HARNESS_GITHUB_TOKEN = "github_pat_..."
#     bash/zsh:    export HARNESS_GITHUB_TOKEN="github_pat_..."
# Use a fine-grained PAT with: Issues=RW, Pull requests=RW, Metadata=R, Contents=RW.
# (Pull requests=RW is what lets a merge-opted-in repo's pr_review loop merge to main.)
schema_version = 1

[instance]
instance_id = "win-desktop"          # e.g. "win-desktop" / "mac-laptop". MUST be unique per machine.
display_name = "Parthiv Windows PC"
platform = "windows"                 # windows | macos | linux — informational only

[github]
account = "your-github-username"
repo = "your-github-username/coordination-repo"  # the coordination repo (issues/PRs)
api_base = "https://api.github.com"
use_in_memory_fake = false           # set true to run offline with the in-memory GitHub fake

# Selects the code-gen executor INDEPENDENTLY of the GitHub adapter above.
#   auto  (default) — executor follows use_in_memory_fake (fake => echo, real => Claude)
#   real            — force the real Claude subprocess executor
#   echo            — force the echo stub (e.g. real GitHub + echo, for a no-spend smoke)
# Decoupling lets you do a "dry run": real Claude (real) + fake GitHub
# (use_in_memory_fake=true) spends tokens but makes no GitHub *coordination* API
# writes (issues/labels/PRs). Note: a dev_task run can still `git push` its feature
# branch to origin — only the GitHub API is faked, not git itself.
[execution]
mode = "auto"

[state_store]
backend = "json"
root = ".harness"

[notifier]
selection = "file"
log_path = ".harness/notifications.log"
inbox = ".harness/inbox"

[autonomy]
run_tests = "autonomous"
open_draft_pr = "autonomous"
file_issue = "autonomous"
set_labels = "autonomous"
assign_issue = "autonomous"
review_pr = "autonomous"             # the pr_review loop may post PR reviews/comments
mark_pr_ready = "gated"
dependency_change = "gated"
schema_change = "gated"
# Keep this "forbidden" here. A repo that wants the pr_review loop to MERGE its PRs opts
# in PER-REPO in its own harness.project.toml: [overrides.autonomy] merge_to_main =
# "gated" (review -> human approves merge) | "autonomous" (review -> merge, closed loop).
merge_to_main = "forbidden"
force_push = "forbidden"

[circuit_breakers]
max_iterations = 8
spend_ceiling_usd = 5.0
spend_is_hard_stop = true

# The multi-project scheduler (drives `harness tick` / `harness watch`). Off by
# default; turn it on to let one machine run several repos with different cadences.
[scheduling]
enabled = false
tick_interval_seconds = 300          # base cadence of `harness watch`
max_concurrent_runs = 2              # how many runs may be active at once
global_spend_ceiling_usd = 20.0      # shared cap across ALL projects per window
spend_window = "daily"               # daily | rolling_24h
default_weight = 1.0

# Discord routing. Channel/guild IDs are config (NOT secret); the bot token comes
# from DISCORD_BOT_TOKEN in the environment, never here. Set notifier.selection =
# "discord" to post gates to Discord (they still mirror to the durable file inbox).
[discord]
enabled = false
guild_id = "000000000000000000"
gates_channel_id = "000000000000000000"     # #verification-gates (the human's inbox)
activity_channel_id = "000000000000000000"  # #activity (issues/PRs/labels)
alerts_channel_id = "000000000000000000"    # #alerts (breaker trips, failures)
runs_channel_id = "000000000000000000"      # #runs (lifecycle), optional
poll_after_answer = true

# The local observer dashboard (`harness ui`). A minimized overview of every agent
# that expands to per-run detail; can answer gates and start/abort runs. Binds
# 127.0.0.1 ONLY (never expose it — the actions mutate engine state). Needs the
# `web` extra: `uv sync --extra web`.
[ui]
enabled = false
host = "127.0.0.1"
port = 8765
poll_interval_ms = 1500
allow_actions = true                 # false => read-only viewer (no answer/start/abort)
open_browser = true
board_ttl_seconds = 20               # cache for GitHub-derived board reads

# Register each managed project as a pointer to where its repo sits on THIS disk.
# The project's own config (owner, build/test commands, prompts, [project].goals)
# lives in that repo's harness.project.toml.
#
# You usually DON'T hand-write these blocks. Instead, onboard a repo with:
#     harness add-project ../some-repo --repo owner/some-repo [--id some-repo] [--autonomous]
# which detects the repo's build/test commands, scaffolds its harness.project.toml,
# and appends the pointer below for you. Then provision its coordination labels and
# generate a starter backlog:
#     harness labels-init some-repo
#     harness research some-repo --goals goals.txt   # files harness:queued issues
#
# Other useful verbs:
#     harness doctor                    # preflight: real adapters + token + claude CLI
#     harness install-schedule --apply  # register `harness tick` with the OS scheduler
#
# Example pointer (path is relative to THIS file's directory, or absolute):
[[projects]]
id = "example-repo"
path = "../example-repo"
# config_file = "harness.project.toml"   # optional override of the discovered filename
