# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/

# Virtual envs
.venv/

# Secrets
.env

# Runtime state (durable run records, notifier inbox, artifacts, scheduler ledger)
# at the repo root is machine-local and ignored. EXCEPT .harness/prompts/, which is
# the self-managed harness's own prompt set — version-controlled so the other
# machine reads the identical prompts. The cross-machine substrate is GitHub.
/.harness/*
!/.harness/prompts/
